# ─── Supabase ───────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Nomba Payment Gateway ───────────────────────────────────
# Get from: https://nomba.com/developers → Dashboard → API Keys
# Account ID (your Nomba merchant account UUID)
NOMBA_ACCOUNT_ID=
# OAuth2 Client credentials (from Nomba developer dashboard)
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
# Use sandbox for testing: https://sandbox.nomba.com/v1
NOMBA_API_BASE=https://api.nomba.com/v1

# ─── Shipbubble Shipping ─────────────────────────────────────
# Get from: https://app.shipbubble.com → Settings → API Keys
SHIPBUBBLE_API_KEY=sb_sandbox_xxxxx

# Your store's address details (used as shipment origin)
SHIPBUBBLE_STORE_ADDRESS=Pen Library Services, Port Harcourt, Rivers State, Nigeria
SHIPBUBBLE_STORE_PHONE=+2348000000000
SHIPBUBBLE_STORE_EMAIL=penlibrary@email.com

# After first successful rate fetch, copy the sender address_code here to save validation credits
# SHIPBUBBLE_SENDER_ADDRESS_CODE=12345

# ─── Paystack ────────────────────────────────────────────────
# Get from: https://dashboard.paystack.com → Settings → API Keys
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_xxxx
PAYSTACK_SECRET_KEY=sk_live_xxxx

# ─── Email (Resend) ──────────────────────────────────────────
# Get from: https://resend.com → API Keys
# When set, order confirmation emails are sent automatically.
# Leave empty to skip email sending (orders still work).
RESEND_API_KEY=

# ─── Security ────────────────────────────────────────────────
# A random secret to protect the /api/diagnostics endpoint.
# Generate with: openssl rand -hex 32
DIAGNOSTICS_SECRET=

# Secret used to sign admin session cookies (required for admin section to work).
# Generate with: openssl rand -hex 32  — use a DIFFERENT value from DIAGNOSTICS_SECRET
ADMIN_SESSION_SECRET=

# ─── App ─────────────────────────────────────────────────────
# Your production domain (used for sitemap, OG image, auth redirect)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# WhatsApp community invite link (shown on the Book Club page)
NEXT_PUBLIC_WHATSAPP_COMMUNITY_URL=https://chat.whatsapp.com/your-link
